# Example environment variables for FitBro (DO NOT commit real secrets)

# Backend
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>
GENERATIVE_API_KEY=your_gemini_api_key_here

# ZEGO (server-side secret - do NOT expose to clients)
ZEGO_APP_ID=your_zego_app_id_here
ZEGO_SERVER_SECRET=your_zego_server_secret_here

# Frontend (public keys)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
VITE_ZEGO_APP_ID=your_zego_app_id_here
VITE_ZEGO_SERVER_SECRET=your_zego_server_secret_here
